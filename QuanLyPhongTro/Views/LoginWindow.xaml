<Window x:Class="QuanLyPhongTro.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập hệ thống" 
        Height="768" Width="1024"  WindowStartupLocation="CenterScreen" 
        Background="#E5E7EB">
    <Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,40,0,0">
            <TextBlock Text="⠿ " FontSize="22" FontWeight="Bold" Foreground="#3B82F6" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <TextBlock Text="DEVOLT" FontSize="22" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
        </StackPanel>


        <Border Background="White" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Padding="40,50" CornerRadius="12" BorderBrush="#D1D5DB" BorderThickness="1">

            <StackPanel>

                <TextBlock Text="Please Log In" FontSize="26" FontWeight="Bold" Foreground="#1F2937" 
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="to your Devolt Workspace" FontSize="14" Foreground="#6B7280" 
                           HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFirstRun}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Create Initial Admin:" Foreground="#10B981" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,20">
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Height="45" Padding="15,0" Margin="0,0,0,15" VerticalContentAlignment="Center" BorderBrush="#D1D5D8" FontSize="14"/>
                        <TextBlock Text="Fullname" Foreground="#9CA3AF" FontSize="14" VerticalAlignment="Center" Margin="17,0,0,0" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FullName}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding FullName}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    

                </StackPanel>

                <Grid Margin="0,0,0,20">
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                      Height="45" Padding="15,0" VerticalContentAlignment="Center"  BorderBrush="#D1D5DB" FontSize="14"/>

                    <TextBlock Text="Username" Foreground="#9CA3AF" FontSize="14" 
               VerticalAlignment="Center" Margin="17,0,0,0" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Username}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Username}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Grid Margin="0,0,0,30">
                    <PasswordBox x:Name="txtPassword" PasswordChanged="txtPassword_PasswordChanged" 
                 Height="45" Padding="15,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" FontSize="14"/>

                    <TextBlock Text="Password" Foreground="#9CA3AF" FontSize="14" 
               VerticalAlignment="Center" Margin="17,0,0,0" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Password}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Password}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Content="Create Admin Account" Command="{Binding CreateAdminCommand}" 
                        Height="45" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,0,20">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFirstRun}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Sign In" Command="{Binding LoginCommand}" 
                        Height="45" Background="Gray" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,0,20">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoginVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Text="Forgot Password?" Foreground="#6B7280" FontSize="13" 
                           HorizontalAlignment="Center" Margin="0,0,0,8" Cursor="Hand"/>
                <TextBlock Text="Don't have an account? Sign up" Foreground="#6B7280" FontSize="13" 
                           HorizontalAlignment="Center" Cursor="Hand"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>