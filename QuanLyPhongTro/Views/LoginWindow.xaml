<Window x:Class="QuanLyPhongTro.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Đăng nhập hệ thống"
        Height="768" Width="1024"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Input field style -->
        <Style x:Key="LoginInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="CaretBrush" Value="#10B981"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#10B981"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="CaretBrush" Value="#10B981"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#10B981"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary green button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Full-screen dark background with gradient -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#1E293B" Offset="0.5"/>
                <GradientStop Color="#0F2922" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Decorative blobs -->
        <Ellipse Width="480" Height="480"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-120,-120,0,0" Opacity="0.06" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#10B981" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="360" Height="360"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-100,-100" Opacity="0.05" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#3B82F6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Logo top-left -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="40,36,0,0">
            <Border Width="34" Height="34" CornerRadius="9" Margin="0,0,10,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#10B981" Offset="0"/>
                        <GradientStop Color="#059669" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <materialDesign:PackIcon Kind="Domain" Width="20" Height="20"
                                         Foreground="White"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="DEVOLT" FontSize="18" FontWeight="Black" Foreground="White"/>
                <TextBlock Text="Quản lý phòng trọ" FontSize="10" Foreground="#6EE7B7"/>
            </StackPanel>
        </StackPanel>

        <!-- ============ LOGIN CARD ============ -->
        <Border Width="420"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="40,44" CornerRadius="20"
                Background="#162032"
                BorderBrush="#1E3A5F"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="60"
                                  ShadowDepth="8" Opacity="0.45"/>
            </Border.Effect>

            <StackPanel>

                <!-- Card header -->
                <Border Width="52" Height="52" CornerRadius="14"
                        HorizontalAlignment="Center" Margin="0,0,0,22">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#10B981" Offset="0"/>
                            <GradientStop Color="#059669" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <materialDesign:PackIcon Kind="ShieldLockOutline"
                                             Width="28" Height="28"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>

                <TextBlock FontSize="24" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6">
                    <Run Text="Đăng nhập"/>
                </TextBlock>
                <TextBlock Text="Chào mừng trở lại DEVOLT Workspace"
                           FontSize="13" Foreground="#64748B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,36"/>

                <!-- === FIRST RUN: FullName field === -->
                <StackPanel Margin="0,0,0,16">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFirstRun}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Background="#0D2A1F" CornerRadius="8" Padding="10,6"
                            Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="InformationOutline"
                                                     Width="16" Height="16"
                                                     Foreground="#10B981"
                                                     Margin="0,0,8,0"
                                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Thiết lập tài khoản Admin lần đầu"
                                       Foreground="#10B981" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Họ và tên" Foreground="#94A3B8"
                               FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,0">
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource LoginInputStyle}"/>
                        <TextBlock Text="Nhập họ và tên đầy đủ"
                                   Foreground="#475569" FontSize="13"
                                   VerticalAlignment="Center" Margin="17,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FullName}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding FullName}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- Username -->
                <TextBlock Text="Tên đăng nhập" Foreground="#94A3B8"
                           FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,16">
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource LoginInputStyle}"/>
                    <TextBlock Text="Nhập tên đăng nhập"
                               Foreground="#475569" FontSize="13"
                               VerticalAlignment="Center" Margin="17,0,0,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Username}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Username}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Password -->
                <TextBlock Text="Mật khẩu" Foreground="#94A3B8"
                           FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,28">
                    <PasswordBox x:Name="txtPassword"
                                 PasswordChanged="txtPassword_PasswordChanged"
                                 Style="{StaticResource LoginPasswordStyle}"/>
                    <TextBlock Text="Nhập mật khẩu"
                               Foreground="#475569" FontSize="13"
                               VerticalAlignment="Center" Margin="17,0,0,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Password}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Password}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Create Admin button -->
                <Button Content="Tạo tài khoản Admin"
                        Command="{Binding CreateAdminCommand}"
                        Margin="0,0,0,14">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFirstRun}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Sign In button -->
                <Button Content="Đăng nhập"
                        Command="{Binding LoginCommand}"
                        Margin="0,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoginVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Footer links -->
                <TextBlock Foreground="#334155" FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,24,0,0">
                    <Hyperlink Foreground="#10B981" TextDecorations="None" Cursor="Hand">
                        Quên mật khẩu?
                    </Hyperlink>
                </TextBlock>

            </StackPanel>
        </Border>

        <!-- Bottom version label -->
        <TextBlock Text="DEVOLT v1.0 · © 2025"
                   Foreground="#1E293B"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,20"/>
    </Grid>
</Window>
