<Window x:Class="QuanLyPhongTro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        
        xmlns:local="clr-namespace:QuanLyPhongTro.Views"
        xmlns:viewmodels="clr-namespace:QuanLyPhongTro.ViewModels"
        
        Title="Phần Mềm Quản Lý Phòng Trọ - DEVOLT" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen" Background="#F3F4F6">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:RoomViewModel}">
            <local:RoomView />
        </DataTemplate>

    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Column="0" Background="#1F2937">
            <StackPanel Margin="0,30,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,50">
                    <TextBlock Text="⠿ " FontSize="26" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                    <TextBlock Text="DEVOLT" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="QUẢN LÝ PHÒNG" Command="{Binding ShowRoomCommand}" Background="LightGray" BorderThickness="0" FontSize="15" Padding="20,15" HorizontalContentAlignment="Left" Cursor="Hand"/>
                <Button Content="KHÁCH THUÊ" Command="{Binding ShowTenantCommand}" Background="LightGray" BorderThickness="0" FontSize="15" Padding="20,15" HorizontalContentAlignment="Left" Cursor="Hand"/>
                <Button Content="HỢP ĐỒNG" Command="{Binding ShowContractCommand}" Background="LightGray" BorderThickness="0" FontSize="15" Padding="20,15" HorizontalContentAlignment="Left" Cursor="Hand"/>
                <Button Content="HÓA ĐƠN" Command="{Binding ShowInvoiceCommand}" Background="LightGray" BorderThickness="0" FontSize="15" Padding="20,15" HorizontalContentAlignment="Left"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="LightGray" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="25,0">
                <Grid>
                    <TextBlock Text="{Binding CurrentUser.FullName, StringFormat='Xin chào, {0}! 👋'}" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="#374151" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrenUser.Role, StringFormat='Chức vụ: {0}'}" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="White" FontWeight="SemiBold"/>
                        <Button Command="{Binding LogoutCommand}" Cursor="Hand" Foreground="White" FontWeight="Bold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#EF4444" CornerRadius="5" Padding="15,8">
                                        <TextBlock Text="Đăng xuất" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" Margin="20"/>
        </Grid>
    </Grid>
</Window>
