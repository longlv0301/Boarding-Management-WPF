<UserControl x:Class="QuanLyPhongTro.Views.MeterReadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="0,0,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,20,0" BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="CHỐT ĐIỆN NƯỚC" FontSize="20" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,25"/>

                <TextBlock Text="Chọn phòng:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding RentedRooms}" SelectedItem="{Binding SelectedRoom}" 
                          DisplayMemberPath="Name" Height="40" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#D1D5DB" Margin="0,0,0,15"/>

                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Tháng:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Month, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Text="Năm:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                </UniformGrid>

                <Border Background="#F3F4F6" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="⚡ SỐ ĐIỆN" FontWeight="Bold" Foreground="#D97706" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="Số cũ:" Foreground="#4B5563" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ElectricOld, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"/>
                            </StackPanel>
                            <StackPanel Margin="5,0,0,0">
                                <TextBlock Text="Số mới:" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ElectricNew, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#3B82F6" BorderThickness="2"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Background="#F3F4F6" CornerRadius="5" Padding="10" Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="💧 SỐ NƯỚC" FontWeight="Bold" Foreground="#0284C7" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="Số cũ:" Foreground="#4B5563" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding WaterOld, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"/>
                            </StackPanel>
                            <StackPanel Margin="5,0,0,0">
                                <TextBlock Text="Số mới:" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding WaterNew, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#3B82F6" BorderThickness="2"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Button Content="💾 Lưu Số Liệu" Command="{Binding SaveCommand}" 
                        Height="45" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand" Margin="0,0,0,10"/>

                <Button Content="Làm Mới" Command="{Binding ClearCommand}" 
                        Height="35" Background="#9CA3AF" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="LỊCH SỬ ĐIỆN NƯỚC CỦA PHÒNG" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding RoomHistory}" 
          SelectedItem="{Binding SelectedRecord}" 
          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
          Background="White" RowHeight="40" ColumnHeaderHeight="45" BorderBrush="#E5E7EB">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tháng" Binding="{Binding Month}" Width="0.6*"/>
                        <DataGridTextColumn Header="Năm" Binding="{Binding Year}" Width="0.6*"/>

                        <DataGridTextColumn Header="Điện Cũ" Binding="{Binding ElectricOld}" Width="*"/>
                        <DataGridTextColumn Header="Điện Mới" Binding="{Binding ElectricNew}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Nước Cũ" Binding="{Binding WaterOld}" Width="*"/>
                        <DataGridTextColumn Header="Nước Mới" Binding="{Binding WaterNew}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>