<UserControl x:Class="QuanLyPhongTro.Views.InvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="0,0,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,20,0" BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="TÍNH TIỀN &amp; LẬP HĐ" FontSize="20" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,25"/>

                <TextBlock Text="Chọn phòng (Đang thuê):" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding RentedRooms}" SelectedItem="{Binding SelectedRoom}" 
                          DisplayMemberPath="Name" Height="40" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#D1D5DB" Margin="0,0,0,15"/>

                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Tháng:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SelectedMonth, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Text="Năm:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SelectedYear, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"/>
                    </StackPanel>
                </UniformGrid>

                <TextBlock Text="Đơn giá Điện (VNĐ/kWh):" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox Text="{Binding ElectricPrice, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,15"/>

                <TextBlock Text="Đơn giá Nước (VNĐ/khối):" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox Text="{Binding WaterPrice, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,15"/>

                <TextBlock Text="Phụ phí (Rác, Wifi... VNĐ):" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox Text="{Binding OtherFees, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,25"/>

                <Button Content="Tạo Hóa Đơn &amp; Tính Tiền" Command="{Binding CreateInvoiceCommand}" 
                        Height="45" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="QUẢN LÝ THU TIỀN THÁNG" FontSize="20" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>

                    <Button Grid.Column="2" Content="💰 Gạch nợ (Đã Thu Tiền)" Command="{Binding PayInvoiceCommand}" 
                            Padding="20,0" Height="40" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    <Button Grid.Column="1" Content="🗑️ Hủy/Xóa Hóa Đơn" Command="{Binding DeleteInvoiceCommand}" 
        Margin="0,0,10,0" Padding="15,0" Height="35" Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right"/>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Invoices}" SelectedItem="{Binding SelectedInvoice}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="White" RowHeight="40" ColumnHeaderHeight="45" BorderBrush="#E5E7EB">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding Id}" Width="0.5*"/>
                        <DataGridTextColumn Header="Phòng" Binding="{Binding Room.Name}" Width="*"/>
                        <DataGridTextColumn Header="Tháng" Binding="{Binding Month, StringFormat=\{0:D2\}}" Width="0.6*"/>
                        <DataGridTextColumn Header="Năm" Binding="{Binding Year}" Width="0.8*"/>
                        <DataGridTextColumn Header="Tiền phòng" Binding="{Binding RoomFee, StringFormat=\{0:N0\}}" Width="*"/>
                        <DataGridTextColumn Header="Tiền điện" Binding="{Binding ElectricFee, StringFormat=\{0:N0\}}" Width="*"/>
                        <DataGridTextColumn Header="Tiền nước" Binding="{Binding WaterFee, StringFormat=\{0:N0\}}" Width="*"/>
                        <DataGridTextColumn Header="Phụ phí" Binding="{Binding OtherFees, StringFormat=\{0:N0\}}" Width="*"/>

                        <DataGridCheckBoxColumn Header="Đã đóng" Binding="{Binding IsPaid}" Width="0.8*"/>
                        <DataGridTextColumn Header="Ngày thu" Binding="{Binding PaidDate, StringFormat=dd/MM/yyyy}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>