<Window x:Class="QuanLyPhongTro.Views.RoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quản Lý Phòng Trọ" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="7*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="THÔNG TIN PHÒNG" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <TextBlock Text="Tên phòng:"/>
                <TextBox Text="{Binding RoomName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Padding="5"/>

                <TextBlock Text="Giá phòng cơ bản (VNĐ):"/>
                <TextBox Text="{Binding BasePrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Padding="5"/>

                <TextBlock Text="Số người ở tối đa:"/>
                <TextBox Text="{Binding MaxOccupants, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,25" Padding="5"/>

                <Button Content="THÊM MỚI" Command="{Binding AddCommand}" 
                        Background="#4CAF50" Foreground="White" FontWeight="Bold" Padding="8" Margin="0,0,0,10"/>

                <Button Content="CẬP NHẬT" Command="{Binding UpdateCommand}" 
                        Background="#FF9800" Foreground="White" FontWeight="Bold" Padding="8" Margin="0,0,0,10"/>

                <Button Content="XÓA TRẮNG FORM" Command="{Binding ClearFormCommand}" 
                        Background="#9E9E9E" Foreground="White" FontWeight="Bold" Padding="8"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Column="1" AutoGenerateColumns="False" CanUserAddRows="False"
                  ItemsSource="{Binding Rooms}" 
                  SelectedItem="{Binding SelectedRoom, Mode=TwoWay}"
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Tên phòng" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Giá cơ bản" Binding="{Binding BasePrice, StringFormat={}{0:N0} VNĐ}" Width="120"/>
                <DataGridTextColumn Header="Số người tối đa" Binding="{Binding MaxOccupants}" Width="120"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>